# ─── Server Configuration ───────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── MongoDB ─────────────────────────────────────────────────────────
# Get your connection string from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Auth ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── Loggly (Cloud Log Management) ───────────────────────────────────
# Get your token from: https://your-subdomain.loggly.com/tokens
LOGGLY_TOKEN=your_loggly_token_here
LOGGLY_SUBDOMAIN=your_loggly_subdomain_here

# ─── AI Incident Analysis (Step 5) ───────────────────────────────────
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Webhook URL: Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
